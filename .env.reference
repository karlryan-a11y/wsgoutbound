# =============================================================================
# WSG Outbound — Environment Variable Reference
# =============================================================================
# This file documents all env vars, their status, and where to find them.
# The actual values are in .env.local (gitignored).
# Last updated: 2026-05-21
# =============================================================================

# ---- APP ----
NEXT_PUBLIC_APP_URL=http://localhost:3000          # CONFIGURED
NODE_ENV=development                                # CONFIGURED

# ---- SUPABASE ----
# Project: oujiouxbtckkxwfohoyy (automation@watsonstylegroup.com)
# Dashboard: https://supabase.com/dashboard/project/oujiouxbtckkxwfohoyy
NEXT_PUBLIC_SUPABASE_URL=                           # CONFIGURED - Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=                      # CONFIGURED - Settings > API > anon/public key
SUPABASE_SERVICE_ROLE_KEY=                          # CONFIGURED - Settings > API > service_role key

# ---- CLERK ----
# Dashboard: https://dashboard.clerk.com (causal-dragon-97)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=                  # CONFIGURED
CLERK_SECRET_KEY=                                   # CONFIGURED
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in              # CONFIGURED
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up              # CONFIGURED
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/               # CONFIGURED
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/               # CONFIGURED

# ---- INNGEST ----
# Dashboard: https://app.inngest.com
# Dev server: npx inngest-cli@latest dev -u http://localhost:3000/api/inngest
INNGEST_EVENT_KEY=                                  # CONFIGURED
INNGEST_SIGNING_KEY=                                # CONFIGURED
INNGEST_DEV=1                                       # CONFIGURED - set to 1 for local dev

# ---- ANTHROPIC (Claude API) ----
# Console: https://console.anthropic.com
# IMPORTANT: Claude Code sets an empty system-level ANTHROPIC_API_KEY.
# next.config.ts has a dotenv override fix, but you can also start dev with:
#   ANTHROPIC_API_KEY="sk-ant-..." npm run dev
ANTHROPIC_API_KEY=                                  # CONFIGURED - Console > API Keys
ANTHROPIC_MODEL=claude-sonnet-4-6                   # CONFIGURED - Default model

# ---- VOYAGE AI (Embeddings) ----
# Dashboard: https://dash.voyageai.com
VOYAGE_API_KEY=                                     # CONFIGURED
VOYAGE_MODEL=voyage-3                               # CONFIGURED - 1024 dimensions

# ---- LEADMAGIC (Email Enrichment) ----
# Account: karl@utilitysavings.ai
# Credits: 4,539 available (1 credit per email lookup)
# Dashboard: https://app.leadmagic.io
LEADMAGIC_API_KEY=                                  # CONFIGURED - lm_live_... key
LEADMAGIC_BASE_URL=https://api.leadmagic.io         # CONFIGURED

# ---- INSTANTLY (Email Sending) ----
# Dashboard: https://app.instantly.ai
INSTANTLY_API_KEY=                                  # CONFIGURED - base64 encoded key
INSTANTLY_BASE_URL=https://api.instantly.ai/api/v2  # CONFIGURED

# ---- BIGQUERY (Contact Warehouse) ----
# Project: golden-keel-492520-g3
# Auth: ADC locally (gcloud auth application-default login)
# Auth: Service account JSON for Vercel (need to create or work around org policy)
# Tables:
#   apollo.people       - 93M rows (standard Apollo export)
#   apollo.linkedin_us  - 39.9M rows (richer: job_summary, company_size)
#   apollo.orgs         - 6M rows (generic column names, needs mapping)
GCP_PROJECT_ID=golden-keel-492520-g3                # CONFIGURED
GCP_BIGQUERY_DATASET=apollo                         # CONFIGURED
GCP_BIGQUERY_LOCATION=US                            # CONFIGURED

# ---- DEBUG ----
DEBUG_LOG_PROMPTS=1                                 # CONFIGURED - logs prompts/responses to debug_log table
RATE_LIMIT_LEADMAGIC_RPS=5                          # CONFIGURED
RATE_LIMIT_ANTHROPIC_RPS=10                         # CONFIGURED

# =============================================================================
