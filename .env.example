# =============================================================================
# WSG Outbound — Environment Variables
# =============================================================================
# Copy this file to `.env.local` for development.
# Set the same values in Vercel project settings for production.
# Never commit `.env.local`. Never log these values.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Development: http://localhost:3000
# Production: your Vercel domain (e.g. https://campaigns.watsonstylegroup.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Supabase
# Project: wsgoutbound
# Dashboard: https://oujiouxbtckkxwfohoyy.supabase.co
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://oujiouxbtckkxwfohoyy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Project Settings → API → anon public
SUPABASE_SERVICE_ROLE_KEY=              # Project Settings → API → service_role (SERVER ONLY, never expose)

# -----------------------------------------------------------------------------
# Clerk (auth)
# Dashboard: https://dashboard.clerk.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=      # Clerk → API Keys → Publishable
CLERK_SECRET_KEY=                       # Clerk → API Keys → Secret
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# -----------------------------------------------------------------------------
# Inngest (async + human-in-loop orchestration)
# Dashboard: https://app.inngest.com
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=                      # Inngest → Settings → Event Keys
INNGEST_SIGNING_KEY=                    # Inngest → Settings → Signing Keys
INNGEST_DEV=1                           # 0 in production; 1 locally

# -----------------------------------------------------------------------------
# Anthropic (Claude — SQL gen, copy gen, personalization)
# Console: https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=                      # Console → API Keys
ANTHROPIC_MODEL=claude-sonnet-4-6       # Default; switch to claude-opus-4-7 for copy if voice matters

# -----------------------------------------------------------------------------
# Voyage AI (embeddings for knowledge base RAG)
# Dashboard: https://dash.voyageai.com
# -----------------------------------------------------------------------------
VOYAGE_API_KEY=                         # Voyage → API Keys
VOYAGE_MODEL=voyage-3                   # 1024 dimensions — match `knowledge.embedding` vector type

# -----------------------------------------------------------------------------
# LeadMagic (email find + validate + mobile + LinkedIn enrichment)
# Account: WSG's LeadMagic account
# Docs: https://docs.leadmagic.io
# -----------------------------------------------------------------------------
LEADMAGIC_API_KEY=                      # WSG LeadMagic dashboard → API Keys
LEADMAGIC_BASE_URL=https://api.leadmagic.io

# -----------------------------------------------------------------------------
# Instantly v2 (campaign push + sending)
# Account: WSG's Instantly account
# Docs: https://developer.instantly.ai
# -----------------------------------------------------------------------------
INSTANTLY_API_KEY=                      # Instantly → Integrations → API
INSTANTLY_BASE_URL=https://api.instantly.ai/api/v2

# -----------------------------------------------------------------------------
# BigQuery (prospect data source — Karl's GCP project, read-only service account)
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=                         # Your GCP project ID
GCP_BIGQUERY_DATASET=                   # Dataset name WSG can read from
GCP_BIGQUERY_LOCATION=US                # Or wherever your dataset lives
# Paste the full service account JSON as a single-line string.
# In Vercel, paste it into the env var value — multiline is fine there.
# Locally, use \n escapes or store the JSON file and load via GOOGLE_APPLICATION_CREDENTIALS instead.
GCP_SERVICE_ACCOUNT_JSON=

# Alternative for local dev: path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/Users/karl/.gcp/wsgoutbound-bq-sa.json

# -----------------------------------------------------------------------------
# Optional — debug & ops
# -----------------------------------------------------------------------------
DEBUG_LOG_PROMPTS=1                     # Log full LLM prompts/responses to debug table (dev only)
RATE_LIMIT_LEADMAGIC_RPS=5              # Throttle LeadMagic calls
RATE_LIMIT_ANTHROPIC_RPS=10             # Throttle Anthropic calls
